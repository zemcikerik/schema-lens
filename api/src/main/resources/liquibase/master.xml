  <changeSet id="2025-11-07T1520-data-model-relationship-type"
             author="Erik Zemčík (zemcik.erik@gmail.com)">
    <!-- '1' -> one-to-one relationship -->
    <!-- 'N' -> one-to-many relationship -->
    <sql dbms="oracle"
         splitStatements="false">
      ALTER TABLE data_model_relationship
      ADD CONSTRAINT cc_data_model_relationship_type CHECK (type IN ('1', 'N'))
    </sql>

    <rollback>
      <sql dbms="oracle"
           splitStatements="false">
        ALTER TABLE data_model_relationship
        DROP CONSTRAINT cc_data_model_relationship_type
      </sql>
    </rollback>
  </changeSet>

