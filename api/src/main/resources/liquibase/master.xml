             author="Erik Zemčík (zemcik.erik@gmail.com)">
    <sql dbms="oracle"
         splitStatements="false">
      ALTER TABLE data_model_relationship
      ADD CONSTRAINT cc_data_model_relationship_no_identifying_self_reference CHECK (
        from_entity_id &lt;&gt; to_entity_id OR is_identifying = 0
      )
    </sql>

    <rollback>
      <sql dbms="oracle"
           splitStatements="false">
        ALTER TABLE data_model_relationship
        DROP CONSTRAINT cc_data_model_relationship_no_identifying_self_reference
